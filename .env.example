# Reviewer identity — must match a file in reviewers/<name>.md
REVIEWER=cyrus

# Model routing — which model to use for each call type
MODEL_DISCOVER=haiku
MODEL_REVIEW_SIMPLE=haiku
MODEL_REVIEW_COMPLEX=sonnet
MODEL_JUDGE=haiku

# Dashboard API key — required for mutation endpoints (trigger, cron, merge)
# Generate with: openssl rand -hex 16
API_KEY=your-api-key-here
