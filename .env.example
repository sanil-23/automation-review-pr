# Target repo path (auto-detected if not set)
REPO_DIR=/Users/cyrus/Desktop/Code/tinyhuman/openhuman.ai/openhuman

# Reviewer identity — must match a file in reviewers/<name>.md
REVIEWER=cyrus

# Model routing — which model to use for each call type
MODEL_DISCOVER=haiku
MODEL_REVIEW_SIMPLE=haiku
MODEL_REVIEW_COMPLEX=sonnet
MODEL_JUDGE=haiku

# Max PRs to review per cron cycle (rest picked up next cycle)
MAX_REVIEWS=5

# Telegram notifications (optional)
# Create a bot via @BotFather, get the token
# Get chat ID by messaging the bot and checking https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dashboard API key — required for mutation endpoints (trigger, cron, merge)
# Generate with: openssl rand -hex 16
API_KEY=your-api-key-here

# ─────────────────────────────────────────────────────────────────────────────
# PR Reviewer + Autonomous Takeover system (Cron 1/2/3)
# ─────────────────────────────────────────────────────────────────────────────

# Target repo (owner/name) the reviewer operates on. Reviews + merges land here.
REVIEW_REPO=sanil-23/automation-review-pr

# Your GitHub login. In-scope = PRs that mention / request-review-from / are
# assigned to ME, plus PRs not authored by ME that link an assigned issue.
ME=sanil-23

# Reviewer identity file: reviewers/<REVIEWER>.md
REVIEWER=sanil

# Stall thresholds (hours). Cron 3 takes a PR over once the author has been
# silent for STALL_HOURS; the hourly run reports activity within STALL_PROBE_HOURS.
STALL_HOURS=24
STALL_PROBE_HOURS=12

# full = auto-close losing dup PRs + auto-merge the winner once CI + CodeRabbit
# are green. Anything else = stop before close/merge and queue for manual confirm.
AUTONOMY=full

# How many takeover fixes run in parallel (Cron 3 fan-out).
TAKEOVER_CONCURRENCY=5

# Dedicated working clone for `vendor/review` (never the harness working tree).
TAKEOVER_CLONE=.takeover-clone

# Per-PR FSM state store (one state/pr-<N>.json per PR).
STATE_DIR=state
