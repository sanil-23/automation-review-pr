# Target repo path (auto-detected if not set)
REPO_DIR=/Users/cyrus/Desktop/Code/tinyhuman/openhuman.ai/openhuman

# Reviewer identity — must match a file in reviewers/<name>.md
REVIEWER=cyrus

# Model routing — which model to use for each call type
MODEL_DISCOVER=haiku
MODEL_REVIEW_SIMPLE=haiku
MODEL_REVIEW_COMPLEX=sonnet
MODEL_JUDGE=haiku

# Max PRs to review per cron cycle (rest picked up next cycle)
MAX_REVIEWS=5

# Telegram notifications (optional)
# Create a bot via @BotFather, get the token
# Get chat ID by messaging the bot and checking https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dashboard API key — required for mutation endpoints (trigger, cron, merge)
# Generate with: openssl rand -hex 16
API_KEY=your-api-key-here
