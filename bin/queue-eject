#!/usr/bin/env bash
# Eject a PR from whichever queue it's in (dashboard "remove" action).
#
# Usage: queue-eject <pr> [reason]
#
# If a takeover worker is mid-flight on the PR, its process is killed and its
# tmux window closed first. The PR then moves to DISMISSED, which every cron
# ignores (so it won't be re-reviewed, re-queued, or taken over). Re-include it
# later by deleting state/pr-<N>.json or letting scout rediscover it as NEW.
set -uo pipefail
PR="${1:?usage: queue-eject <pr> [reason]}"; REASON="${2:-ejected from dashboard}"
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"; cd "$SCRIPT_DIR"
[ -f .env ] && { set -a; . ./.env; set +a; }
: "${TAKEOVER_TMUX_SESSION:=super-review}"
source lib/state.sh

if ! state_exists "$PR"; then echo "no state for #$PR"; exit 1; fi
prev="$(state_get "$PR" .fsm_state)"

# Kill an in-flight takeover worker, if any.
PIDF="$SCRIPT_DIR/.queue/worker-$PR.pid"
if [ -f "$PIDF" ]; then
  pid="$(cat "$PIDF" 2>/dev/null || true)"
  if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
    kill "$pid" 2>/dev/null || true
    echo "killed worker pid $pid for #$PR"
  fi
  rm -f "$PIDF"
fi
if command -v tmux >/dev/null 2>&1; then
  tmux kill-window -t "${TAKEOVER_TMUX_SESSION}:pr-${PR}" 2>/dev/null || true
fi

state_set_json "$PR" worker_slot null
state_set_json "$PR" fix_phase null
fsm_set "$PR" DISMISSED "$REASON (was $prev)"
echo "#$PR ejected ($prev -> DISMISSED): $REASON"
