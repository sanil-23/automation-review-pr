#!/bin/bash
# Review a single PR
# Usage: review <PR_NUMBER>
#   e.g: review 2750

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

if [ -z "${1:-}" ]; then
    echo "Usage: review <PR_NUMBER>"
    echo "  e.g: review 2750"
    exit 1
fi

echo "Reviewing PR #$1..."
bash "${SCRIPT_DIR}/review-single.sh" "$1"
