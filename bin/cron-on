#!/bin/bash
# NOTE: Automated scheduling (crontab/launchd) is disabled on this machine
# because macOS blocks background processes from accessing ~/Desktop.
#
# Use these instead:
#   npm run cron:run       — run a full cycle now
#   npm run review -- 2750 — review a single PR
#   Dashboard "Run Now"    — trigger from the web UI
#
echo "Automated cron is not available (macOS Desktop permissions)."
echo ""
echo "Use instead:"
echo "  npm run cron:run         — run full cycle now"
echo "  npm run review -- <PR>   — review a single PR"
echo "  Dashboard 'Run Now'      — http://localhost:3847/cron.html"
